# Chiffon Configuration
# Copy to .env and fill in real values before starting.
# Generate strong passwords: openssl rand -base64 32

# ── Database ──────────────────────────────────────────────────────────────────
DB_USER=agent
DB_PASSWORD=change-me
DB_NAME=agent_deploy

# ── Message Broker (RabbitMQ) ─────────────────────────────────────────────────
RABBITMQ_USER=agent
RABBITMQ_PASSWORD=change-me

# ── LLM Providers ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── LiteLLM Proxy ─────────────────────────────────────────────────────────────
LITELLM_MASTER_KEY=change-me

# ── Ollama ────────────────────────────────────────────────────────────────────
# Default: local container. Override for remote GPU host (e.g. spraycheese).
OLLAMA_BASE_URL=http://ollama:11434

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
